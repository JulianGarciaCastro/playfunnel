        <script src="https://stackpath.bootstrapcdn.com/bootstrap/4.5.2/js/bootstrap.min.js" 	integrity="sha384-B4gt1jrGC7Jh4AgTPSdUtOBvfO8shuf57BaghqFfPlYxofvL8/KUEfYiJOMMV+rV" crossorigin="anonymous"></script>
        <!------------SCRIPTS PAGE-->
        <script type="text/javascript">

    		var currentTab ="VIDEO";

          	$(document).ready(function(){
    			//$(".searchUp").click(function(){
            	//	$(".search").toggleClass("active");
            	//});

              	$("#deleteMediaFileBtn").hide();

    			$("#viewVideos").click(function(){
            		$("#tabVideos").addClass("active");
            		$("#tabImages").removeClass("active");
            		currentTab="VIDEO";
            		updateViewDivs();

            	});

            	$("#viewImages").click(function(){
              		$("#tabVideos").removeClass("active");
              		$("#tabImages").addClass("active");
              		currentTab="IMAGE";
              		updateViewDivs();
            	});


            	updateViewDivs();
            	updateModalEvent();
          	});

            //Selected Media
            const selectInputsMedia = (element) => {
                console.log('CARGO INPUTS');
                let inputsMedia = document.querySelectorAll('.checkMedia');
                inputsMedia.forEach((element)=>{
                    selectMedia(element);
                })
            }

            //function
            const selectMedia = (element) => {
                // element.removeEventListener("change", () =>{}); // Fallo
                element.addEventListener("change", (event) => {
                    if (element.checked) {
                        element.parentNode.classList.add('selected');
                    }
                    else{
                        element.parentNode.classList.remove('selected');
                    }
            });}
            //call funtion
            selectInputsMedia();




          	function updateViewDivs(){
          		console.log("Updating views");
                  selectInputsMedia();
          		if(currentTab=="IMAGE"){
          			$('div[media-type="VIDEO"]').each(function () {
            			$(this).hide();
            		});

            		$('div[media-type="IMAGE"]').each(function () {
            			$(this).show();
            		});
          		}
          		else{
          			$('div[media-type="VIDEO"]').each(function () {
            			$(this).show();
            		});

            		$('div[media-type="IMAGE"]').each(function () {
            			$(this).hide();
            		});
          		}
          	}


            function updateModalEvent(){
          		$('input[type=checkbox]').click(function(){
            		var one_checked = false

            		$('input[type=checkbox]').each(function () {
            			if(this.checked){
            				one_checked = true;
            				return;
            			}
            		});

            		if(one_checked){
            			$("#deleteMediaFileBtn").show();
            		}else{
            			$("#deleteMediaFileBtn").hide();
            		}
        		});
          	}


    		function uploadMedia(input) {
            	if (input.files && input.files[0]) {
            		//alert("Filename: " + input.files[0].name);
            		//alert("Type: " + input.files[0].type);
            		//alert("Size: " + input.files[0].size + " bytes");

            		/*
                	var fileTypes = ['svg','jpg', 'jpeg', 'png', 'bmp','mp4', 'avi', 'wmv', 'etc'];

                	//if(currentTab =='IMAGE')
                	//	fileTypes = ['svg','jpg', 'jpeg', 'png', 'bmp'];
                	//else
                	//	fileTypes = ['mp4', 'avi', 'wmv', 'etc'];

                	var extension = input.files[0].name.split('.').pop().toLowerCase(); 	//file extension from input file
                	var isSuccess = fileTypes.indexOf(extension) > -1;  					//is extension in acceptable types

                	if(!isSuccess){
                		alert('Tipo de Archivo no valido, tipos aceptados: ' + fileTypes);
                		$("#mediaFile")[0].value = '';
                		return null;
                	}

                	var fileTypesImg = ['svg','jpg', 'jpeg', 'png', 'bmp'];
            		var fileTypesVid = ['mp4', 'avi', 'wmv', 'etc'];

                	var isSuccessImg = fileTypesImg.indexOf(extension) > -1;
                	var isSuccessVid = fileTypesVid.indexOf(extension) > -1;
					var mediaType;

                	if(isSuccessImg){
						mediaType="IMAGE";
					}
					else if(isSuccessVid){
						mediaType="VIDEO";
					}
					*/

                	if(input.files[0].type.match('image/*'))
                		mediaType = 'IMAGE';
                	else if(input.files[0].type.match('video/*'))
                		mediaType = 'VIDEO';
                	else{
                		//alert('Tipo de Archivo no valido, tipos aceptados: IMAGEN or VIDEO');
                		modalMsgShow('Tipo de Archivo no valido, tipos aceptados: IMAGEN or VIDEO');
                		$("#mediaFile")[0].value = '';
                		return null;
                    }

                	var reader = new FileReader();

                    reader.onload = function (e) {
        				var form = new FormData();
        				form.append('_token', $("input[name=_token]").val());
        				form.append('mediaFile', input.files[0]);
        				form.append('mediaType',  mediaType);
                        $('#uploadMediaModal').modal('show');
                        //cache: false,

                        $.ajax({
                        	url:  '/ajax-addMedia',
                        	type: 'POST',
                        	data: form,
            				contentType: false,
            				processData: false,
            				dataType: 'json',
            				async:true,
            				xhr: function() {
                        		var xhr = new window.XMLHttpRequest();
                                xhr.upload.addEventListener("progress", function(evt) {
                                	if (evt.lengthComputable) {
                                    	var percentComplete = evt.loaded / evt.total;
                                    	console.log(percentComplete);
                                    	percentComplete = parseInt(percentComplete * 100);
                                    	console.log(percentComplete);
                                		$('#progressBar').val(Math.round(percentComplete));
                                    	if (percentComplete >= 100) {
                                			$("#uploadMediaModal").modal('hide');
                                			setTimeout(
                            				  function(){
                            					console.log("voy a cerrar modal despues de 3 sec");
                            				    $("#uploadMediaModal").modal("hide");
                            				  }, 1500);
                                    	}
                                    }
                                }, false);
                                return xhr;
                         	},
                            success: function(response){
                            	if(response.success == 'Y') {
                            		newDiv = makeDiv(response.file, response.id, response.type, response.media);
                            		$('#myMedia').append(newDiv);
                            		updateModalEvent();
                            		updateViewDivs();
                            		$("#uploadMediaModal").modal('hide');
                            		$("#mediaFile")[0].value = '';

                            		setTimeout(
                    				  function(){
                    					console.log("voy a cerrar modal despues de 3 sec");
                    				    $("#uploadMediaModal").modal("hide");
                    				  }, 1500);
                            	}
                            	else{
                            		console.log( 'Errores: ' + response.error );
                            		//alert( response.error );
                            		modalMsgShow(response.error);
                            		$("#mediaFile")[0].value = '';
                            	}
                            	$("#uploadMediaModal").modal('hide');
                                selectInputsMedia();
                            	setTimeout(
                				  function(){
                					console.log("voy a cerrar modal despues de 3 sec");
                				    $("#uploadMediaModal").modal("hide");
                				  }, 1500);
                            },
                            error: function(request, error){
                				console.log(error);
                				console.log(request);
                				//alert(JSON.stringify(error));
                				modalMsgShow(JSON.stringify(error));
                				$("#mediaFile")[0].value = '';
                				$('#uploadMediaModal').modal('hide');
                				setTimeout(
                				  function(){
                					console.log("voy a cerrar modal despues de 3 sec");
                				    $("#uploadMediaModal").modal("hide");
                				  }, 1500);
            				}
                        });
                    }

                    reader.readAsDataURL(input.files[0]);

                }
            }

            $("#mediaFile").change(function () {
            	uploadMedia(this);
            });


    		function makeDiv( url, id, type, media ){
    			var newMedia = $('<img class="" />');
        		newMedia.attr('src', 		url);
        		newMedia.attr('media-src', 	media);
        		newMedia.attr('media-id',  	id);

        		var playVideo="";
        		if(type=="VIDEO"){
        			media = "'" + media + "'";
        			playVideo = 'ondblclick="playVideo('+ media +')"';
        		}
        		if(type=="IMAGE"){
        			media = "'" + media + "'";
        			playVideo = 'ondblclick="playImage('+ media +')"';
        		}

        		var innerDiv = '<div id="newDiv-'+id+'" name="newDiv-'+id+'" media-type="'+type+'" class="cards col-3 mt-3 mx-2 p-0">'
              		 		+	'<div class=" options d-flex col-12 justify-content-end p-0"'+playVideo+'>'
                			+		'<input type="checkbox" class="selecter mt-2 mr-2 checkMedia" id="checkMedia" name="'+id+'">'
                			+		'<button class="deleter ml-2 mb-2" id="' + id + '" name="'+ id +'" onclick="deleteMedia(' + id + ')" ><i class="fas fa-trash"></i></button>'
              				+	'</div>'
            				+'</div>';
            	//onclick="deleteMedia(' + id + ')"
            	//data-toggle="modal" data-target="#deleteMedia"
            	var newDiv = $(innerDiv);
            	newMedia.appendTo(newDiv);
    			return newDiv;
    		}




    		function deleteAllMediaBtn(){

    			$('input[type=checkbox]').each(function () {
        			if(this.checked){
        				var name = "#newDiv-"+$(this).attr("name");
        				console.log("Borrando: " + name)
        				deleteMediaAux($(this).attr("name"));
        			}
        		});

        		$("#deleteMediaFileBtn").hide();
        		$('#deleteAllMediaModal').modal('hide');
    		}


    		function deleteMediaAux( id ){
    			var form = new FormData();
    			form.append('_token', $("input[name=_token]").val());
    			form.append('id', id);

    			$.ajax({
            		url:  '/ajax-delMedia',
                	type: 'POST',
                	data: form,
                	cache: false,
        			contentType: false,
        			processData: false,
        			dataType: 'json',
                	success: function(response){
                  		if(response.success == 'Y') {
                  			var name = "#newDiv-"+id;
                  			$(name).remove();
                  		}
                  		else if(response.success == 'N') {
                  			//alert(response.message);
                  			modalMsgShow(JSON.stringify(error));
                  		}
                  		else{
							console.log('Respuesta: %o', response);
                        }
                	},
                	error: function(request, error){
        				console.log(error);
        				console.log(request);
        				//alert("Error: "+JSON.stringify(error));
        				modalMsgShow(JSON.stringify(error));
        			}
               	});
    		}


    		function deleteMedia(id){
    			$('#deleteMediaModal').modal('show');
    			currentID=id;
    		}

    		function deleteMediaModalBtn(){
    			deleteMediaAux(currentID);
    			$('#deleteMediaModal').modal('hide');
    			currentID=null;
    		}


    		function playVideo(media){
    			$('source', $('#playVideo')).attr('src', media);

    			$('#playMediaModal').modal('show');
    			$('#playVideo').get(0).load();
    			//$('#playVideo').get(0).play();
    		}

    		function stopVideo(){
    			$('#playVideo').get(0).pause();
    		}



    		function playImage(media){
    			$('#playImage').attr('src', media);
    			$('#playImageModal').modal('show');
    		}

    		function modalMsgClose() {
    			$('#msgModal').modal('hide');
    		}

            function modalMsgShow(texto) {
    			$("#modalMsgContent").text(texto);
    			$("#msgOK").attr("onClick","modalMsgClose()")
    			//$('#msgModal').modal('show');
    			//setTimeout(
    			//	function(){
                //       $("#msgModal").modal("hide");
                //    }, 2000);
    			$('#msgModal').modal('show');
        	}
        </script>
    </body>
</html>
