<script>
  window.onload = function() { 
    
    /*---------Langs--*/
    $("#langs-down").click(function() {
      $("#langs a").each(function(){
          if(!$(this).hasClass("active")){
              $(this).toggleClass("d-none");       
          }else{
            $(this).parent().prepend($(this));
          }   
      });
      $("#langs-down").toggleClass("rotate"); 
    });
  }
</script>
