        /*-------------------------------------------COPY------*/

        $("#copyIframe").click(function() {
          copyToClipBoard("iframe");
        });

        $("#copyUrl").click(function() {
          copyToClipBoard("url");
        });

        function copyToClipBoard(type) {
          if(type=="iframe") {
            $("#iframeLink").text();
            navigator.clipboard.writeText( $("#iframeLink").text());
          }
          else if(type=="url") {
            $("#UrlLink").text();
            navigator.clipboard.writeText( $("#UrlLink").text());
          }

        }

