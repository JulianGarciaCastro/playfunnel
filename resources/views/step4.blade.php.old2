        function selectImageMedia(){
    		    console.log("selectImageMedia()");
            var blnSelected = false;

            $('input[type=checkbox]').each(function () {
            	if(this.checked){
            		var name = $(this).attr("name");
            		console.log("Seleccionado: " + name)

            		var mediaId  = $(this).parent().next().attr("media-id");
            		var mediaSrc = $(this).parent().next().attr("media-src");
            		var mediaImg = $(this).parent().next().attr("src");

            		blnSelected = true;
            		$(this).prop("checked", false);

                console.log("mediaSrc: " + mediaSrc)
                $('#endVideoimage').attr("src", mediaSrc);
                $('#endVideoimageId').val(name);
            	}
            });

            if(blnSelected)
            	$('#libraryModal').modal('hide');
		    }



        function boton_guardar(){

          console.log("boton_guardar(): línea <?= (__LINE__ - 1) ?>");

          if(!existsChanges()){
            console.log("compruebo cambios---------------------")
            //alert("No hay modificaciones"+ " Linea 442");
            modalMsgShow("No hay modificaciones");
            return;
          }

          var form = new FormData();
          form.append('_token',     $("input[name=_token]").val());
          var publish_library_img = $('#endVideoimageId').val();
          form.append('projectid',  <?= $_REQUEST['project'] ?>);
          console.log("projectid: "+<?= $_REQUEST['project'] ?>);
          form.append('publish_library_img',publish_library_img);
          form.append('publish_div',$('#endVideoContent').html());

          //form.append('libraryid',  $('#projectVideo').attr("media-id"));
          //form.append('cuepoints',  JSON.stringify(cuePoints));
          if(existsChanges()){
            $.ajax({
                url:  '/ajax-setPublishData',
                type: 'POST',
                data: form,
                cache: false,
                contentType: false,
                processData: false,
                dataType: 'json',
                success: function(response){
                  if(response.success == 'Y') {
                    //loadCuepoints();
                    //alert(response.message);
                    ProjectModalSave();
                    //cuePoints = response.cuePoints;
                    //console.log("boton_guardar() Los CuePoints Guardados: %o", response.cuePoints);

                    //$.each(cuePoints, function(i, item) {
                    //  item.action = "READY";
                    //});
                  }
                  if(response.success == 'N') {
                  	//alert("Error: " + response.message + "Linea <?= (__LINE__ - 1) ?>" );
                	modalMsgShow("Error: " + response.message);
                  }
                },
                error: function(request, error){
                  console.log(error);
                  console.log(request);
                  //alert("Error: "+JSON.stringify(error) + "Linea <?= (__LINE__ - 1) ?>");
                  modalMsgShow("Error: "+JSON.stringify(error));
                }
            });
          }

        }


