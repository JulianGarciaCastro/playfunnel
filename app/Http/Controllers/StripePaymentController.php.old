<?php
  
namespace App\Http\Controllers;
  
use Illuminate\Http\Request;
use Session;
use Stripe;

use App\Models\User;
use App\Models\PlanType;
use App\Models\PlanSubscription;
use Illuminate\Support\Facades\Auth;
use Illuminate\Support\Facades\Log;
use Illuminate\Support\Facades\View;
use Carbon\Carbon;

class StripePaymentController extends Controller
{
    /**
     * success response method.
     *
     * @return \Illuminate\Http\Response
     */
    public function stripe(Request $request){
        $user = Auth::user();
        if(is_null($user)){
            return redirect('/login');
        }
        
        $plan = PlanType::where('id', $request->id)->where('active', '1')->first();
        if(is_null($plan)){
            return redirect('/account');
        }
        
        Log::debug('Productos: ' . $this->stripeProduts($request));
        //Log::debug('Upcoming: ' . $this->stripeUpcoming($request));
        
        return View::make('stripe', compact('plan'));
    }
    
    /**
     * success response method.
     *
     * @return \Illuminate\Http\Response
     */
    public function stripePost(Request $request){
        $user = Auth::user();
        
        $plan = PlanType::where('id', $request->id)->where('active', '1')->first();
        
        if(is_null($plan)){
            return redirect('/account');
        }
        
        Stripe\Stripe::setApiKey(env('STRIPE_SECRET'));
        
        if(is_null($user->customernum)){
            $customer = Stripe\Customer::create([
                'description' => 'Create user for payments, ' . $user->id,
                'email'  => $user->email,
                'name'   => $user->name,
                'source' => $request->stripeToken,
            ]);
            
            $user->customernum = $customer->id;
            $user->save();
        }
        else{
            Stripe\Customer::update($user->customernum, ['source' => $request->stripeToken]);
        }
        
        //DEPRECATED
        /*
        $sourceCard = \Stripe\Customer::retrieveSource($customerNum, $request->stripeToken);
        
        if(is_null ($sourceCard)){
            $sourceCard = Stripe\Customer::createSource(
                            $customerNum,
                            ['source' => $request->stripeToken]
                          );
        }       
        
        Log::debug('Source Card: ' . $sourceCard);
        */
        
        //Cargo Unico
        /*
        $payment = Stripe\Charge::create ([
            "amount"         => $plan->price * 100,
            "currency"       => "eur",
            //"source" => $request->stripeToken,
            "description"    => "Payment PlayFunnel plan " . $plan->price . "€/" . $plan->name ." - " . $plan->size ."GB",
            "receipt_email"  => $user->email,
            "customer"       => $user->customernum,
        ]);
        */
        
        //Subscription
        $payment = Stripe\Subscription::create([
            'customer' => $user->customernum,
            'currency' => 'eur',
            'description'=> $plan->name,
            'items'    => [['price' => $plan->pricenum, 'quantity'=> 1, ]],
        ]);
        
        Log::debug('Payment: ' . $payment);
        
        
        $user->subscribePlan( $plan, $payment->id );
        
        Session::flash('success', 'Payment successful!');
        
        return back();
    }
    
    
    public function stripeCancel(Request $request){
        $user = Auth::user();
        $message = $user->cancelCurrentSubscription();
        return response()->json(['success'=>'Y', 'message'=>$message]);
    }
    
    
    public function stripeProduts(Request $request){
        Stripe\Stripe::setApiKey(env('STRIPE_SECRET'));
        $stripe = new \Stripe\StripeClient(env('STRIPE_SECRET'));
        $produts = $stripe->products->all();
        
        foreach($produts as $produt) { 
            $price = $stripe->prices->retrieve($produt->default_price, []);
            $produt['price'] = $price;
        }
        
        return $produts;
    }
    
    
    public function stripeUpcoming(Request $request){
        Stripe\Stripe::setApiKey(env('STRIPE_SECRET'));
        $stripe = new \Stripe\StripeClient(env('STRIPE_SECRET'));
        
        $user = Auth::user();
        $commingInvoice = $stripe->invoices->upcoming(['customer' => $user->customernum]);
        
        return $commingInvoice;
    }
    
    
    public function stripeUserSubscriptions(Request $request){
        $user = Auth::user();
        $stripe = new \Stripe\StripeClient(env('STRIPE_SECRET'));
        
        $subscriptions = $stripe->subscriptions->all(['customer' => $user->customernum, 'status' => 'all']);
        //Log::debug('stripeUserSubscriptions() Subscriptions: ' . $subscriptions);
        
        foreach($subscriptions as $subscription) { 
            $invoices = $stripe->invoices->all(['subscription' => $subscription->id]);
            $subscription['invoices'] =$invoices;
            //Log::debug('stripeUserSubscriptions() Invoices: ' . $invoices);
        }
        
        Log::debug('stripeUserSubscriptions() Subscriptions: ' . $subscription );
        return $subscriptions;
    }
    
    
}