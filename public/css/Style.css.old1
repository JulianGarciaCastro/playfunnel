    .aspect ul li .active {
      background: #00026a; }

.btn-float {
  position: fixed;
  top: 70px;
  right: 0px;
  z-index: 10; }
  .btn-float button {
    max-width: 40px;
    background: #B6C8DD;
    border: none;
    color: #fff;
    border-radius: 100px;
    padding: 8px;
    outline: none !important;
    transition: background 1.5s;
    align-items: center; }
    .btn-float button:hover {
      color: #00caf1;
      background: #00026a;
      transition: background 1.5s; }
    .btn-float button i {
      font-size: 22px !important; }
    .btn-float button.btn-save {
      background: #2DD1DB;
      max-width: 80px; }
      .btn-float button.btn-save:hover {
        background: #00026a;
        transition: background 1.5s; }

.rightMenu {
  overflow: inherit;
  max-width: 380px;
  padding-bottom: 30px !important;
  max-width: 100%; }
  .rightMenu input {
    border-radius: 6px;
    box-shadow: none;
    border: solid #B6C8DD 1.5px;
    color: #B6C8DD; }
    .rightMenu input:active, .rightMenu input:focus {
      border: solid #00caf1 1.5px;
      color: #00026a;
      outline: none; }
  .rightMenu .arraysCue {
    counter-reset: section;
    height: 63vh !important;
    overflow-y: scroll; }
    @media screen and (max-width: 768px) {
      .rightMenu .arraysCue {
        height: 40vh !important; } }
    .rightMenu .arraysCue .array_item {
      word-wrap: break-word !important; }
      .rightMenu .arraysCue .array_item::before {
        counter-increment: section;
        content: counter(section);
        margin-right: 1rem;
        color: #73A1C2; }
  .rightMenu .next {
    position: absolute;
    bottom: 20px;
    width: 100%;
    margin: 0 auto;
    left: 0;
    padding: 0 !important; }
  @media only screen and (min-width: 992px) {
    .rightMenu {
      overflow: hidden;
      max-width: 380px; } }

