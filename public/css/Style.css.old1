    #videoContainer #containerFather #progressContainer {
      position: absolute;
      bottom: 10px;
      left: 4%;
      width: 92%;
      height: 4px;
      background: #3F51B5;
      cursor: pointer;
      border-radius: 14px; }
      #videoContainer #containerFather #progressContainer #progress {
        position: absolute;
        top: 0;
        left: 0;
        height: 100%;
        background: #2196F3; }
      #videoContainer #containerFather #progressContainer .marker {
        position: absolute;
        top: -2px;
        width: 8px;
        height: 8px;
        border-radius: 50%;
        background: #ffffff;
        cursor: pointer; }
        #videoContainer #containerFather #progressContainer .marker::after {
          content: '';
          width: 18px;
          height: 18px;
          border: 2px solid #ffffff61;
          border-radius: 50%;
          position: absolute;
          top: -5px;
          left: -5px;
          box-sizing: border-box; }

