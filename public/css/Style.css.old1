          .librery .containerPage .content .tables {
            padding-bottom: 260px !important; } }
        .librery .containerPage .content .tables .message {
          width: 100%;
          height: 100%;
          display: flex;
          justify-content: center;
          align-items: center; }
          @media screen and (max-width: 768px) {
            .librery .containerPage .content .tables .message {
              height: auto; } }
      .librery .containerPage .content .downMenu {
        z-index: 10;
        position: sticky;
        bottom: 0;
        height: 90px;
        width: 100%; }
        @media screen and (max-width: 768px) {
          .librery .containerPage .content .downMenu {
            height: 60px;
            position: absolute; } }

.libraryPage {
  height: 100%;
  position: relative;
  padding-left: 280px !important;
  background-color: #E8EFF7; }
  .libraryPage .main {
    height: 100%; }
    .libraryPage .main .title {
      min-height: 120px;
      background-color: #E8EFF7;
      position: static; }
      .libraryPage .main .title h2 {
        padding-top: 30px;
        padding-left: 50px; }
    .libraryPage .main .content {
      min-height: 88%;
      width: 100%;
      padding: 0 6vw !important;
      -webkit-box-shadow: 27px 13px 43px -31px rgba(0, 2, 106, 0.3);
      -moz-box-shadow: 27px 13px 43px -31px rgba(0, 2, 106, 0.3);
      box-shadow: 27px 13px 43px -31px rgba(0, 2, 106, 0.3); }
      @media screen and (max-width: 768px) {
        .libraryPage .main .content {
          padding: 0 3vw  !important;
          transition: padding 0.3s; } }
      .libraryPage .main .content .tabl {
        width: 100%;
        position: relative; }
        .libraryPage .main .content .tabl .folder {
          background-color: none;
          max-width: 100%; }
          .libraryPage .main .content .tabl .folder a {
            color: #C6C6C7; }
        .libraryPage .main .content .tabl .active {
          background-color: #F2F5F9;
          color: #00026a;
          border-right: solid #00026a; }
          .libraryPage .main .content .tabl .active a {
            color: #00026a; }
          @media screen and (max-width: 768px) {
            .libraryPage .main .content .tabl .active {
              border-right: none #00026a;
              border-bottom: solid #00026a; } }
      .libraryPage .main .content .tables {
        z-index: 9;
        height: 100%;
        align-content: baseline; }
        .libraryPage .main .content .tables .message {
          width: 100%;
          height: 100%;
          display: flex;
          justify-content: center;
          align-items: center; }
          @media screen and (max-width: 768px) {
            .libraryPage .main .content .tables .message {
              height: auto; } }
  @media screen and (max-width: 768px) {
    .libraryPage {
      padding-left: 0px !important;
      transition: padding-left 0.3s; } }

.cards {
  height: 150px;
  max-width: 260px !important;
  min-width: 260px !important;
  background-color: #fff; }
  .cards img {
    object-fit: contain;
    padding: 10px;
    height: 100% !important;
    width: 100% !important;
    max-width: 100%; }
  .cards .options {
    position: absolute;
    width: 100%;
    height: 100%;
    opacity: 0; }
    .cards .options:hover {
      opacity: 1; }
    .cards .options.selected {
      border: dotted #00caf1 4px; }
    .cards .options .selecter {
      position: absolute; }
    .cards .options .deleter {
      position: absolute;
      bottom: 0;
      background: none;
      color: #9B51E0;
      left: 0;
      border: none;
      border-radius: 0 !important; }
      .cards .options .deleter:hover {
        border: none;
        border-radius: 0 !important;
        color: #00026a; }

.options.selected {
  opacity: 1; }

