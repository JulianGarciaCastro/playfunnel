  border-radius: 50px;
  transition: background 1.5s;
  outline: none !important;
  font-size: 15px; }
  .btn-square-80:hover {
    border-radius: 8px; }

.btn-cMain-box {
  max-height: 48px;
  background: #00026a;
  color: #fff;
  border: none;
  border-radius: 6px;
  padding: 9px 18px;
  min-width: 170px;
  transition: background 1.5s;
  outline: none !important;
  font-size: 0.9rem !important; }
  .btn-cMain-box:hover {
    background: #00caf1;
    color: #fff;
    transition: background 1.5s; }
  .btn-cMain-box i {
    font-size: 18px !important; }

.btn-cMain {
  height: 48px;
  background: #00026a;
  color: #fff;
  border: none;
  border-radius: 50px;
  padding: 9px 8px;
  width: 170px;
  transition: background 1.5s;
  outline: none !important; }
  .btn-cMain:hover {
    background: #00caf1;
    color: #fff;
    transition: background 1.5s; }
  .btn-cMain i {
    font-size: 16px !important; }

.btn-cCancel {
  max-height: 46px;
  background: #73A1C2;
  color: #fff;
  border-radius: 50px;
  padding: 9px 8px;
  width: 170px;
  transition: background 1.5s;
  outline: none !important; }
  .btn-cCancel:hover {
    background: #00caf1;
    color: #fff;
    transition: background 1.5s; }
  .btn-cCancel i {
    font-size: 16px !important; }

.btn-WhiteBorder {
  max-height: 46px;
  height: fit-content;
  background: none;
  border: solid 2px #fff;
  color: #fff;
  border-radius: 50px;
  padding: 9px 8px;
  width: 170px;
  outline: none !important;
  transition: background 1.5s; }
  .btn-WhiteBorder:hover {
    border: solid 2px #00caf1;
    color: #00caf1;
    transition: background 1.5s; }

.btn-WhiteText {
  height: fit-content;
  background: none;
  border: none;
  color: #fff;
  border-radius: 50px;
  padding: 9px 8px;
  outline: none !important;
  transition: background 1.5s; }
  .btn-WhiteText:hover {
    color: #00caf1;
    transition: background 1.5s; }
  .btn-WhiteText i {
    font-size: 16px !important; }

.previewPanel {
  display: flex;
  justify-content: center;
  align-items: center; }
  .previewPanel li {
    border-radius: 6px;
    background-color: #B6C8DD;
    list-style-type: none; }
  .previewPanel .active {
    background-color: #00caf1; }

.activePanel {
  font-size: 14px;
  /* Rounded sliders */ }
  .activePanel .switch {
    position: relative;
    display: inline-block;
    width: 50px;
    height: 24px; }
  .activePanel .switch input {
    opacity: 0;
    width: 0;
    height: 0; }
  .activePanel .slider {
    position: absolute;
    cursor: pointer;
    top: 0;
    left: 0;
    right: 0;
    bottom: 0;
    background-color: #C6C6C7;
    -webkit-transition: .4s;
    transition: .4s; }
  .activePanel .slider:before {
    position: absolute;
    content: "";
    height: 20px;
    width: 20px;
    left: 2px;
    bottom: 2px;
    background-color: white;
    -webkit-transition: .4s;
    transition: .4s; }
  .activePanel input:checked + .slider {
    background-color: #00caf1; }
    .activePanel input:checked + .slider.disable {
      background-color: #C6C6C7;
      opacity: 0.2; }
  .activePanel input:checked + .slider:before {
    -webkit-transform: translateX(26px);
    -ms-transform: translateX(26px);
    transform: translateX(26px); }
  .activePanel .slider.round {
    border-radius: 34px; }
  .activePanel .slider.round:before {
    border-radius: 50%; }

.billing th {
  border: none !important; }
.billing td {
  border: none !important; }
.billing tr {
  border-bottom: solid 1px #00caf1 !important; }

.card-dash {
  -webkit-box-shadow: -11px 16px 34px -7px rgba(0, 202, 241, 0.1);
  -moz-box-shadow: -11px 16px 34px -7px rgba(0, 202, 241, 0.1);
  box-shadow: -11px 16px 34px -7px rgba(0, 202, 241, 0.1);
  border-radius: 1rem;
  padding: 1rem; }

/*---------------------------------------MEDIA QUERYS*/
.selectBlue {
  width: 268px;
  padding: 5px;
  font-size: 16px;
  line-height: 1;
  border: 0;
  border-radius: 5px;
  height: 34px;
  background: url(../images/SVG/selectDropDown.svg) no-repeat right #fff;
  -webkit-appearance: none;
  background-position-x: 98%; }

.contentIframe {
  margin: 0 auto;
  display: flex;
  width: 100%;
  height: 70%;
  justify-content: center;
  background: #e8eff7;
  border: 0px dotted #B6C8DD;
  border-radius: 8px;
  padding: 0rem; }

.p-desktop {
  width: 90vw;
  height: calc(90vw/1.77); }
  .p-desktop.prev {
    width: 90vw;
    height: calc(90vw/1.77); }
  @media only screen and (min-width: 992px) {
    .p-desktop {
      width: 800px;
      height: 450px; }
    .p-desktop.prev {
      width: 90vh;
      height: calc(90vh/1.77); } }
  @media only screen and (min-width: 1440px) {
    .p-desktop {
      width: 1024px;
      height: 576px; }
    .p-desktop.prev {
      width: 90vw;
      height: calc(90vw/1.77); } }
  @media only screen and (min-width: 1920px) {
    .p-desktop {
      width: 1280px;
      height: 720px; }
    .p-desktop.prev {
      width: 80vw;
      height: calc(80vw/1.77); } }
  @media only screen and (min-width: 2560px) {
    .p-desktop {
      width: 1920px;
      height: 1080px; }
    .p-desktop.prev {
      width: 50vw;
      height: calc(50vw/1.77); } }

.p-tablet {
  width: 340px;
  height: 450px; }
  @media only screen and (min-width: 992px) {
    .p-tablet {
      width: 478px;
      height: 636px; } }
  @media only screen and (min-width: 1920px) {
    .p-tablet {
      width: 675px;
      height: 900px; } }

.p-mobile {
  height: calc(375px*1.77);
  width: 375px;
  max-height: calc(375px*1.77);
  max-width: 375px; }
  @media only screen and (min-width: 400px) {
    .p-mobile {
      width: 375px;
      height: calc(375px*1.77); } }
  @media (orientation: landscape) {
    .p-mobile {
      width: 375px;
      height: calc(375px*1.77); } }

.br-r1 {
  border-radius: 0.5rem; }

.f169aspect {
  width: 100% !important;
  height: 56vw !important;
  position: absolute; }
  @media (orientation: portrait) {
    .f169aspect {
      width: 100% !important;
      height: 56vw !important; } }

.f916aspect {
  width: 56vh !important;
  max-width: 100%;
  height: 100vh !important;
  position: absolute; }

.f133aspect {
  width: 100vh !important;
  height: 100vh !important;
  position: absolute; }
  @media (orientation: portrait) {
    .f133aspect {
      width: 100vw !important;
      height: 100vw !important; } }

output {
  width: 20px;
  margin-bottom: -5px; }

.slider-alpha, .sliderWidth, .slider-history {
  width: auto;
  -webkit-appearance: none;
  height: 4px;
  background: #E8EFF7;
  outline: none;
  opacity: 1;
  -webkit-transition: .2s;
  transition: opacity .2s;
  min-width: 70px; }
  .slider-alpha::-webkit-slider-thumb, .sliderWidth::-webkit-slider-thumb, .slider-history::-webkit-slider-thumb {
    -webkit-appearance: none;
    appearance: none;
    border-radius: 100%;
    width: 10px;
    height: 10px;
    background: #00026a;
    cursor: pointer; }
  .slider-alpha::-webkit-slider-thumb, .sliderWidth::-webkit-slider-thumb, .slider-history::-webkit-slider-thumb {
    -webkit-appearance: none;
    background-color: #00026a;
    width: 20px;
    height: 20px;
    border-radius: 50%;
    border: 2px solid white;
    cursor: pointer;
    transition: .3s ease-in-out; }

#langs {
  position: absolute;
  top: 18px;
  left: -20px; }

#langs-2 {
  position: absolute;
  top: 18px;
  right: 100px; }

#langs-3 {
  position: absolute;
  right: 5%; }

#langs-down {
  font-size: 22px;
  cursor: pointer; }
  #langs-down.rotate {
    transform: rotateZ(180deg); }

.options.selected {
  opacity: 1; }

