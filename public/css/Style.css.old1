.cards {
  height: 150px;
  max-width: 260px !important;
  min-width: 260px !important;
  background-color: #fff; }
  .cards img {
    object-fit: contain;
    padding: 10px;
    height: 100% !important;
    width: 100% !important;
    max-width: 100%; }
  .cards .options {
    position: absolute;
    width: 100%;
    height: 100%;
    opacity: 0; }
    .cards .options:hover {
      opacity: 1; }
    .cards .options.selected {
      border: dotted #00caf1 4px; }
    .cards .options .selecter {
      position: absolute; }
    .cards .options .deleter {
      position: absolute;
      bottom: 0;
      background: none;
      color: #9B51E0;
      left: 0;
      border: none;
      border-radius: 0 !important; }
      .cards .options .deleter:hover {
        border: none;
        border-radius: 0 !important;
        color: #00026a; }

.options.selected {
  opacity: 1; }

