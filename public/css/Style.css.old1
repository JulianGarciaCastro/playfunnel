.aspect ul {
  display: grid;
  grid-column-gap: 16px;
  grid-template-columns: auto auto auto;
  width: 200px;
  justify-content: space-around;
  padding: 0;
  margin: 0 auto !important; }
  .aspect ul li {
    list-style-type: none;
    padding: 0.5rem;
    display: flex;
    flex-direction: column; }
