span {
  cursor: pointer; }

/*BUTTONS*/
.btn-cBlue {
  max-height: 46px;
  background: #00caf1;
  color: #fff;
  border-radius: 50px;
  padding: 9px 8px;
  width: 170px;
  transition: background 1.5s;
  outline: none !important; }
  .btn-cBlue:hover {
    background: #00caf1;
    color: #fff;
    transition: background 1.5s; }
  .btn-cBlue i {
    font-size: 16px !important; }

.btn-basic {
  height: 48px;
  border: none;
  border-radius: 50px;
  padding: 9px 8px;
  transition: background 1.5s;
  outline: none !important; }
  .btn-basic i {
    font-size: 16px !important; }
  .btn-basic:hover {
    border-radius: 8px; }

.btn-square {
  justify-content: center;
  height: fit-content;
  align-items: center;
  display: flex;
  padding: 10px;
  border: none;
  border-radius: 50px;
  transition: background 1.5s;
  outline: none !important;
  font-size: 15px; }
  .btn-square:hover {
    border-radius: 8px; }

.btn-round {
  justify-content: center;
  align-items: center;
  display: flex;
  padding: 10px;
  border: none;
