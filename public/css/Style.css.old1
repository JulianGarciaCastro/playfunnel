  background: none;
  color: none; }
  .poster #resizable h3 {
    text-align: center;
    margin: 0; }
  .poster #resizable .ui-resizable-helper {
    border: 2px dotted #00F; }
  .poster #resizable .ui-resizable-s {
    cursor: s-resize;
    height: 7px;
    width: 100%;
    bottom: 0px;
    display: flex;
    left: 0%;
    border-bottom: 0px dotted #00026a;
    justify-content: center;
    align-items: center;
    padding-top: 6px;
    opacity: 0.2 !important;
    transition: opacity 1s; }
    .poster #resizable .ui-resizable-s::before {
      background: #4eb3ea;
      border-radius: 20px;
      width: 20px;
      display: flex;
      text-align: center;
      justify-content: center;
      height: 20px;
      padding-right: 0px;
      align-items: center;
      padding: 10;
      position: absolute;
      content: "⭥";
      color: white;
      font-size: 14px; }
  .poster #resizable .ui-resizable-e {
    cursor: e-resize;
    width: 7px;
    display: flex;
    right: 0%;
    border-right: dotted 0px #00026a;
    justify-content: center;
    align-items: center;
    padding-left: 10px;
    height: 100%;
    opacity: 0.2 !important;
    transition: opacity 1s; }
    .poster #resizable .ui-resizable-e::before {
      background: #4eb3ea;
      border-radius: 20px;
      width: 20px;
      display: flex;
      text-align: center;
      justify-content: center;
      height: 20px;
      padding-right: 6px;
      align-items: center;
      padding: 10;
      position: absolute;
      content: "⭤";
      color: white;
      font-size: 14px; }
  .poster #resizable .ui-icon-gripsmall-diagonal-se {
    display: none !important; }
  .poster #resizable img {
    height: 100%;
    width: 100%;
    object-fit: contain;
    border-radius: 15px;
    background: none !important;
    border: none !important; }
  .poster #resizable #imgGetIn {
    opacity: 0.2 !important;
    transition: opacity 1s; }
  .poster #resizable:hover #imgGetIn, .poster #resizable:hover .ui-resizable-e, .poster #resizable:hover .ui-resizable-s {
    opacity: 1 !important;
    transition: opacity 1s; }
  .poster #resizable.imgOn {
    display: flex; }
  .poster #resizable.imgOff {
    display: none; }
