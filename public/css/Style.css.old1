input[type=date], input[type=datetime-local], input[type=month], input[type=time] {
  -webkit-appearance: listbox;
  border: none;
  background: none;
  display: block;
  position: relative;
  font-size: 1rem;
  font-family: monospace;
  border: none;
  cursor: pointer; }

::-webkit-calendar-picker-indicator {
  position: absolute;
  width: 2.5rem;
  height: 100%;
  top: 0;
  right: 0;
  bottom: 0;
  opacity: 0;
  cursor: pointer; }

.dashboard {
  height: calc(100% - 60px);
  top: 60px; }
  .dashboard .sideNav {
    background-color: #fff;
    max-width: 280px;
    height: 100%;
    position: relative;
    z-index: 10;
    left: 0px;
    -webkit-box-shadow: 27px 13px 43px -31px rgba(0, 2, 106, 0.3);
    -moz-box-shadow: 27px 13px 43px -31px rgba(0, 2, 106, 0.3);
    box-shadow: 27px 13px 43px -31px rgba(0, 2, 106, 0.3); }
    .dashboard .sideNav.show {
      left: -280px; }
    @media screen and (max-width: 768px) {
      .dashboard .sideNav {
        position: fixed;
        left: -280px;
        transition: left 0.3s;
        box-shadow: none; }
        .dashboard .sideNav.show {
          left: 0px;
          -webkit-box-shadow: 27px 13px 43px -31px rgba(0, 2, 106, 0.3);
          -moz-box-shadow: 27px 13px 43px -31px rgba(0, 2, 106, 0.3);
          box-shadow: 27px 13px 43px -31px rgba(0, 2, 106, 0.3); } }
    .dashboard .sideNav .nav-item {
      padding-top: 0.5rem; }
      .dashboard .sideNav .nav-item span {
        margin-left: 1rem; }
      .dashboard .sideNav .nav-item a:hover {
        color: #73A1C2; }
  .dashboard .mainContainer {
    background-color: #E8EFF7; }
    .dashboard .mainContainer .main .content {
      height: 96%;
      width: 100%;
      -webkit-box-shadow: 27px 13px 43px -31px rgba(0, 2, 106, 0.3);
      -moz-box-shadow: 27px 13px 43px -31px rgba(0, 2, 106, 0.3);
      box-shadow: 27px 13px 43px -31px rgba(0, 2, 106, 0.3); }

.dashboard-Content, .dashboard-Nav {
  padding-left: 0 !important;
  justify-content: center !important; }
  @media only screen and (min-width: 992px) {
    .dashboard-Content, .dashboard-Nav {
      justify-content: center !important;
      padding-left: 280px !important; } }

.btn-float {
  position: fixed;
  top: 70px;
  right: 0px;
  z-index: 10; }
  .btn-float button {
    max-width: 40px;
    background: #B6C8DD;
    border: none;
    color: #fff;
    border-radius: 100px;
    padding: 8px;
    outline: none !important;
    transition: background 1.5s;
    align-items: center; }
    .btn-float button:hover {
      color: #00caf1;
      background: #00026a;
      transition: background 1.5s; }
    .btn-float button i {
      font-size: 22px !important; }
    .btn-float button.btn-save {
