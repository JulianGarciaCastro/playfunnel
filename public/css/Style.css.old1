  min-height: 24px;
  max-width: 24px;
  max-height: 24px;
  border-radius: 50px;
  transition: background 1.5s;
  outline: none !important;
  font-size: 15px; }
  .btn-round:hover {
    border-radius: 8px; }

.btn-square-min {
  justify-content: center;
